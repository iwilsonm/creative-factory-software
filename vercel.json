{
  "installCommand": "pnpm install --no-frozen-lockfile && cd backend && pnpm install --no-frozen-lockfile && cd ../frontend && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd frontend && pnpm build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": { "memory": 2048, "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api|assets|fonts|favicon|logo).*)", "destination": "/index.html" }
  ]
}
