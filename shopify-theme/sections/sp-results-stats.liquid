{{ 'sp-sections.css' | asset_url | stylesheet_tag }}

{% if section.settings.heading != blank or section.blocks.size > 0 %}
  <style>
    .sp-results-stats-{{ section.id }} {
      background-color: {{ section.settings.bg_color }};
      color: {{ section.settings.text_color }};
      padding: var(--sp-spacing-xl) 0;
    }
    .sp-results-stats-{{ section.id }} .sp-stat-number {
      color: {{ section.settings.stat_color }};
    }
  </style>

  <div class="sp-section sp-results-stats-{{ section.id }}">
    <div class="sp-container" style="text-align:center;">
      {% if section.settings.heading != blank %}
        <h2 class="sp-section-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.intro_text != blank %}
        <p style="max-width:600px;margin:0 auto var(--sp-spacing-lg);opacity:0.9;">{{ section.settings.intro_text }}</p>
      {% endif %}

      <div class="sp-stats-grid">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div {{ block.shopify_attributes }}>
              <div class="sp-stat-number">{{ block.settings.percentage }}</div>
              <div class="sp-stat-desc">{{ block.settings.description }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.caption != blank %}
        <p style="margin-top:var(--sp-spacing-lg);font-size:0.85rem;opacity:0.7;">{{ section.settings.caption }}</p>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "SP Results Stats",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "intro_text", "label": "Intro Text" },
    { "type": "text", "id": "caption", "label": "Caption (below stats)" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#1B4332" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" },
    { "type": "color", "id": "stat_color", "label": "Stat Number Color", "default": "#F59E0B" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "percentage", "label": "Percentage / Number" },
        { "type": "text", "id": "description", "label": "Description" }
      ]
    }
  ]
}
{% endschema %}
