{{ 'sp-sections.css' | asset_url | stylesheet_tag }}

{% if section.settings.heading != blank or section.blocks.size > 0 %}
  <style>
    .sp-benefits-tabs-{{ section.id }} {
      background-color: {{ section.settings.bg_color }};
      padding: var(--sp-spacing-xl) 0;
    }
    .sp-tab-btn-{{ section.id }}.sp-tab-active {
      background-color: {{ section.settings.tab_active_color }};
      color: #ffffff;
      border-color: {{ section.settings.tab_active_color }};
    }
  </style>

  <div class="sp-section sp-benefits-tabs-{{ section.id }}" id="sp-tabs-{{ section.id }}">
    <div class="sp-container">
      {% if section.settings.heading != blank %}
        <h2 class="sp-section-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="sp-tabs-nav" role="tablist">
        {% for block in section.blocks %}
          {% if block.type == 'benefit_tab' %}
            <button
              class="sp-tab-btn sp-tab-btn-{{ section.id }}{% if forloop.first %} sp-tab-active{% endif %}"
              role="tab"
              data-tab="{{ section.id }}-{{ forloop.index0 }}"
              aria-selected="{{ forloop.first }}"
            >{{ block.settings.tab_label }}</button>
          {% endif %}
        {% endfor %}
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'benefit_tab' %}
          <div
            class="sp-tab-panel{% if forloop.first %} sp-tab-active{% endif %}"
            id="sp-panel-{{ section.id }}-{{ forloop.index0 }}"
            role="tabpanel"
            {{ block.shopify_attributes }}
          >
            <div class="sp-tab-panel-content">
              {% if block.settings.tab_heading != blank %}
                <h3>{{ block.settings.tab_heading }}</h3>
              {% endif %}
              {% if block.settings.tab_body != blank %}
                <div style="line-height:1.7;">{{ block.settings.tab_body }}</div>
              {% endif %}
            </div>
            {% if block.settings.tab_image != blank %}
              <div>
                {{ block.settings.tab_image | image_url: width: 800 | image_tag: class: 'sp-img-cover', loading: 'lazy', alt: block.settings.tab_heading }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <script>
    (function() {
      var container = document.getElementById('sp-tabs-{{ section.id }}');
      if (!container) return;
      var btns = container.querySelectorAll('.sp-tab-btn-{{ section.id }}');
      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var tabId = this.getAttribute('data-tab');
          btns.forEach(function(b) { b.classList.remove('sp-tab-active'); b.setAttribute('aria-selected', 'false'); });
          container.querySelectorAll('.sp-tab-panel').forEach(function(p) { p.classList.remove('sp-tab-active'); });
          this.classList.add('sp-tab-active');
          this.setAttribute('aria-selected', 'true');
          var panel = document.getElementById('sp-panel-' + tabId);
          if (panel) panel.classList.add('sp-tab-active');
        }.bind(btn));
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "SP Benefits Tabs",
  "max_blocks": 14,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FAFAF8" },
    { "type": "color", "id": "tab_active_color", "label": "Active Tab Color", "default": "#1B4332" }
  ],
  "blocks": [
    {
      "type": "benefit_tab",
      "name": "Benefit Tab",
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Tab Label" },
        { "type": "text", "id": "tab_heading", "label": "Tab Heading" },
        { "type": "richtext", "id": "tab_body", "label": "Tab Body" },
        { "type": "image_picker", "id": "tab_image", "label": "Tab Image", "info": "Recommended: 800x600px (4:3)" }
      ]
    }
  ]
}
{% endschema %}
