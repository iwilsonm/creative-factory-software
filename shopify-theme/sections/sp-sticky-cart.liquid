{{ 'sp-sections.css' | asset_url | stylesheet_tag }}

{% if section.settings.enabled %}
  <style>
    .sp-sticky-cart-{{ section.id }} {
      background-color: {{ section.settings.bg_color }};
    }
    .sp-sticky-cta-{{ section.id }} {
      background-color: {{ section.settings.cta_color }};
      color: #ffffff;
    }
  </style>

  <div class="sp-sticky-cart sp-sticky-cart-{{ section.id }}" id="sp-sticky-{{ section.id }}">
    <div class="sp-sticky-product-info" id="sp-sticky-info-{{ section.id }}">
      <div id="sp-sticky-text-{{ section.id }}">
        <div style="font-weight:600;font-size:0.95rem;" id="sp-sticky-title-{{ section.id }}"></div>
        <div style="font-size:0.875rem;opacity:0.7;" id="sp-sticky-price-{{ section.id }}"></div>
      </div>
    </div>
    <button class="sp-sticky-cta sp-sticky-cta-{{ section.id }}" id="sp-sticky-btn-{{ section.id }}">
      {{ section.settings.cta_text }}
    </button>
  </div>

  <script>
    (function() {
      var bar = document.getElementById('sp-sticky-{{ section.id }}');
      var titleEl = document.getElementById('sp-sticky-title-{{ section.id }}');
      var priceEl = document.getElementById('sp-sticky-price-{{ section.id }}');
      var btn = document.getElementById('sp-sticky-btn-{{ section.id }}');
      var dataEl = document.getElementById('sp-product-data');

      if (dataEl) {
        try {
          var mode = dataEl.getAttribute('data-mode');
          if (mode === 'text') {
            var title = dataEl.getAttribute('data-title') || '';
            var price = dataEl.getAttribute('data-price') || '';
            var ctaLink = dataEl.getAttribute('data-cta-link') || '';
            if (title) titleEl.textContent = title;
            if (price) priceEl.textContent = price;
            if (btn && ctaLink) {
              btn.addEventListener('click', function() { window.location.href = ctaLink; });
            }
          } else {
            var product = JSON.parse(dataEl.getAttribute('data-product') || '{}');
            if (product.title) titleEl.textContent = product.title;
            if (product.variants && product.variants[0]) {
              var price = (product.variants[0].price / 100).toFixed(2);
              priceEl.textContent = '$' + price;
            }
            if (btn) {
              btn.addEventListener('click', function() {
                var variantId = product.variants && product.variants[0] ? product.variants[0].id : null;
                if (variantId) {
                  fetch('/cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: variantId, quantity: 1 })
                  }).then(function() {
                    window.location.href = '/cart';
                  });
                }
              });
            }
          }
        } catch(e) {}
      }

      var heroEl = document.querySelector('.sp-product-hero-section');
      if (heroEl && bar) {
        var observer = new IntersectionObserver(function(entries) {
          if (!entries[0].isIntersecting) {
            bar.classList.add('sp-visible');
          } else {
            bar.classList.remove('sp-visible');
          }
        }, { threshold: 0 });
        observer.observe(heroEl);
      }
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "SP Sticky Cart",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Enable Sticky Cart", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "text", "id": "cta_text", "label": "Button Text", "default": "Add to Cart" },
    { "type": "color", "id": "cta_color", "label": "Button Color", "default": "#1B4332" }
  ]
}
{% endschema %}
